<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Edit Blog</title>

    <style>
      .blog-container {
        max-width: 800px;
        margin: auto;
      }
    </style>
  </head>

  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-5 blog-container">
      <h3 class="mb-4">Edit Blog</h3>

      <div class="card shadow-sm p-4">
        <form action="/blog/edit/<%= blog._id %>" method="POST">
          <div class="mb-3">
            <label class="form-label">Title</label>
            <input
              type="text"
              class="form-control"
              name="title"
              value="<%= blog.title %>"
              required
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Content</label>
            <textarea class="form-control" rows="8" name="body" required>
<%= blog.body %></textarea
            >
          </div>

          <button class="btn btn-primary">Update Blog</button>

          <a href="/blog/<%= blog._id %>" class="btn btn-secondary ms-2">
            Cancel
          </a>
        </form>
      </div>
    </div>

    <%- include('./partials/script') %>
  </body>
</html>
